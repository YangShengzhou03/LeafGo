# 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=leafgo
DB_USERNAME=root
DB_PASSWORD=your_password

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# 服务端口
SERVER_PORT=8081

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
